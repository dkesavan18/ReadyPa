# Database (PostgreSQL - for future API integration)
DATABASE_URL="postgresql://user:password@localhost:5432/readypa_db"

# Web Push Notifications (generate with web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY="your_vapid_public_key"
VAPID_PRIVATE_KEY="your_vapid_private_key"
VAPID_MAILTO="mailto:admin@readypa.in"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
